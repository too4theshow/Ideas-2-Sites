# ─────────────────────────────────────────────────────────────────────
# Ideas 2 Sites — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
# Guide: docs/TELEGRAM.md
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your Anthropic API key (starts with sk-ant-...)
# Guide: docs/ANTHROPIC.md
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your Netlify personal access token
# Guide: docs/NETLIFY.md
NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token

# ── OPTIONAL — Site Tracking ──────────────────────────────────────────

# Supabase project URL (enables cloud storage + multi-device /mysites)
# Guide: docs/SUPABASE.md
# SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key
# SUPABASE_KEY=your-supabase-anon-key

# ── OPTIONAL — Customization ──────────────────────────────────────────

# Prefix for Netlify site names (e.g., "mybot" → mybot-jazz-history.netlify.app)
# Default: ideas2sites
# SITE_PREFIX=ideas2sites

# Claude model to use. claude-sonnet-4-5 is fast + affordable. Use claude-opus-4-5 for premium quality.
# Default: claude-sonnet-4-5
# CLAUDE_MODEL=claude-sonnet-4-5

# Max sites a user can generate per 24 hours (rate limiting)
# Default: 10
# MAX_SITES_PER_USER=10
